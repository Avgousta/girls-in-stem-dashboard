# ── Supabase ───────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API

# Your project URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/public key (safe to expose in browser — RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose this in the browser or commit to git
# Only used in server-side code / edge functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COHORT_YEAR=2025

# ── Email (Resend) — optional, for notifications ───────────────
# Sign up free at resend.com — 3,000 emails/month free
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.co.za
